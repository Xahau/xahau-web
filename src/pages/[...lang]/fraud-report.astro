---
import FraudReportPage from '../../components/FraudReportPage.astro'
import { fraudReportTranslations } from '../../i18n/fraudReportTranslations'
import { defaultLocale, locales } from '../../i18n/locales'

export function getStaticPaths() {
  return locales.map((locale) => {
    const lang = locale === defaultLocale ? undefined : locale.toLowerCase()
    return {
      params: { lang },
      props: { locale },
    }
  })
}

const { locale } = Astro.props
const t = fraudReportTranslations[locale]
---

<FraudReportPage t={t} />
