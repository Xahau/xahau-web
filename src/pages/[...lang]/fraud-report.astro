---
import FraudReportPage from '../../components/FraudReportPage.astro'
import { fraudReportTranslations } from '../../i18n/fraudReportTranslations'
import { defaultLocale, type Locale, locales } from '../../i18n/locales'

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }))
}

const { lang } = Astro.params
const locale = (lang as Locale) ?? defaultLocale
const t = fraudReportTranslations[locale]
---

<FraudReportPage t={t} />
