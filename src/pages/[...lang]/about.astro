---
import '../../styles/main.css'
import XahauAbout from '../../components/XahauAbout.astro'
import { aboutTranslations } from '../../i18n/aboutTranslations'
import { defaultLocale, type Locale, locales } from '../../i18n/locales'
import BaseLayout from '../../layouts/BaseLayout.astro'

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }))
}

const { lang } = Astro.params
const locale = (lang as Locale) ?? defaultLocale
const t = aboutTranslations[locale]
const _frontmatter = { title: t.page_title, description: t.page_subtitle }
---

<BaseLayout frontmatter={_frontmatter}>
  <div class="page-content flex-1 container mx-auto max-w-7xl p-6">
    <XahauAbout />
  </div>
</BaseLayout>
