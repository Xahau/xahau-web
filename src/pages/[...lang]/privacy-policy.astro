---
import { getEntry, render } from 'astro:content'
import { defaultLocale, locales } from '../../i18n/locales'
import PageLayout from '../../layouts/PageLayout.astro'

export function getStaticPaths() {
  return locales.map((locale) => {
    const lang = locale === defaultLocale ? undefined : locale.toLowerCase()
    return {
      params: { lang },
      props: { locale },
    }
  })
}

const { locale } = Astro.props
const entry = await getEntry('privacy', locale)
if (!entry) return Astro.redirect('/privacy-policy')

const { Content } = await render(entry)
const _frontmatter = {
  title: entry.data.title,
  description: entry.data.description,
}
---

<PageLayout frontmatter={_frontmatter}> <Content /> </PageLayout>
