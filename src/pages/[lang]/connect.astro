---
import '../../styles/main.css'
import XahauConnect from '../../components/XahauConnect.astro'
import connectData from '../../data/connect.json'
import { type Locale, nonDefaultLocales } from '../../i18n/locales'
import BaseLayout from '../../layouts/BaseLayout.astro'

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params
const { title, description } = connectData.meta[lang as Locale]
const _frontmatter = { title, description }
---

<BaseLayout frontmatter={_frontmatter}>
  <div class="page-content flex-1 container mx-auto max-w-7xl p-6">
    <XahauConnect />
  </div>
</BaseLayout>
