---
import '../../styles/main.css'
import XahauFeatures from '../../components/XahauFeatures.astro'
import { featuresTranslations } from '../../i18n/featuresTranslations'
import { type Locale, nonDefaultLocales } from '../../i18n/locales'
import BaseLayout from '../../layouts/BaseLayout.astro'

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params
const t = featuresTranslations[lang as Locale] ?? featuresTranslations.en
const _frontmatter = { title: t.page_title, description: t.page_subtitle }
---

<BaseLayout frontmatter={_frontmatter}>
  <div class="page-content flex-1 container mx-auto max-w-7xl p-6">
    <XahauFeatures />
  </div>
</BaseLayout>
