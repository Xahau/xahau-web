---
import FraudReportPage from '../../components/FraudReportPage.astro'
import { fraudReportTranslations } from '../../i18n/fraudReportTranslations'
import { type Locale, nonDefaultLocales } from '../../i18n/locales'

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params
const t = fraudReportTranslations[lang as Locale]
---

<FraudReportPage t={t} />
